        {
          "name": "Add Track to Playlist",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": { "raw": "{{base_url}}/playlists/1/tracks/add/", "host": ["{{base_url}}"], "path": ["playlists", "1", "tracks", "add", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"track_id\": 1,\n  \"position\": 0\n}"
            }
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"name\": \"Morning Vibes\",\n  \"track_count\": 1,\n  \"tracks\": [\n    { \"id\": 1, \"title\": \"So What\", \"artist\": \"Miles Davis\" }\n  ]\n}"
            },
            {
              "name": "400 Already in playlist",
              "status": "Bad Request",
