{
  "info": {
    "name": "Music Backend API",
    "description": "Full API collection for the Music Backend (Django + DRF). Base URL: http://localhost:8000/api/v1\n\nWorkflow:\n1. Register or Login → copy the `access` token\n2. In each protected request set Header: Authorization: Bearer <access>\n3. Use the `refresh` token at /auth/token/refresh/ when access expires",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8000/api/v1" },
    { "key": "access",   "value": "" },
    { "key": "refresh",  "value": "" }
  ],
  "item": [

    {
      "name": "Auth",
      "item": [

        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/register/", "host": ["{{base_url}}"], "path": ["auth", "register", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"username\": \"alice\",\n  \"password\": \"strongpass123\",\n  \"password2\": \"strongpass123\"\n}"
            },
            "description": "Create a new account. Returns user profile + JWT tokens."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"user\": {\n    \"id\": 1,\n    \"email\": \"alice@example.com\",\n    \"username\": \"alice\",\n    \"avatar\": null,\n    \"bio\": \"\",\n    \"created_at\": \"2024-03-15T10:00:00Z\"\n  },\n  \"tokens\": {\n    \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n  }\n}"
            },
            {
              "name": "400 Bad Request — email taken",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"email\": [\"A user with this email already exists.\"]\n}"
            }
          ]
        },

        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('access',  json.tokens.access);",
                  "pm.collectionVariables.set('refresh', json.tokens.refresh);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/login/", "host": ["{{base_url}}"], "path": ["auth", "login", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"alice@example.com\",\n  \"password\": \"strongpass123\"\n}"
            },
            "description": "Login with email + password. The test script auto-saves tokens to collection variables."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"user\": {\n    \"id\": 1,\n    \"email\": \"alice@example.com\",\n    \"username\": \"alice\",\n    \"avatar\": null,\n    \"bio\": \"\",\n    \"created_at\": \"2024-03-15T10:00:00Z\"\n  },\n  \"tokens\": {\n    \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n    \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n  }\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"detail\": \"Invalid credentials.\"\n}"
            }
          ]
        },

        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access}}" }
            ],
            "url": { "raw": "{{base_url}}/auth/logout/", "host": ["{{base_url}}"], "path": ["auth", "logout", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}"
            },
            "description": "Blacklists the refresh token. Pass the refresh token in the body."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"detail\": \"Successfully logged out.\"\n}"
            }
          ]
        },

        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": { "raw": "{{base_url}}/auth/me/", "host": ["{{base_url}}"], "path": ["auth", "me", ""] },
            "description": "Returns the authenticated user's profile."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"email\": \"alice@example.com\",\n  \"username\": \"alice\",\n  \"avatar\": null,\n  \"bio\": \"Music lover\",\n  \"created_at\": \"2024-03-15T10:00:00Z\"\n}"
            }
          ]
        },

        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{access}}" }],
            "url": { "raw": "{{base_url}}/auth/me/", "host": ["{{base_url}}"], "path": ["auth", "me", ""] },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "bio",      "value": "Music lover & DJ", "type": "text" },
                { "key": "username", "value": "alice_dj",         "type": "text" }
              ]
            },
            "description": "Partial update of the current user's profile. Supports avatar upload (multipart)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"email\": \"alice@example.com\",\n  \"username\": \"alice_dj\",\n  \"avatar\": null,\n  \"bio\": \"Music lover & DJ\",\n  \"created_at\": \"2024-03-15T10:00:00Z\"\n}"
            }
          ]
        },

        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/auth/token/refresh/", "host": ["{{base_url}}"], "path": ["auth", "token", "refresh", ""] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"{{refresh}}\"\n}"
            },
            "description": "Get a new access token using the refresh token."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            }
          ]
        }

      ]
    },

